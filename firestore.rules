rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global default deny
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    // --- GLOBAL HELPERS ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- VALIDATION HELPERS ---

    function isValidUser(data) {
      return data.uid == request.auth.uid
        && data.username is string
        && data.displayName is string
        && data.email is string
        && (data.xp == null || data.xp is number)
        && (data.level == null || data.level is number)
        && (data.createdAt == null || data.createdAt is string)
        && (data.location == null || data.location is string)
        && (data.occupation == null || data.occupation is string)
        && (data.currentTheme == null || data.currentTheme in ['light', 'dark', 'system']);
    }

    function isValidHobby(data) {
      return data.id is string
        && data.name is string
        && data.dailyGoal is number
        && data.weeklyGoal is number
        && (data.streak == null || data.streak is number)
        && (data.totalXp == null || data.totalXp is number);
    }

    function isValidAchievement(data) {
      return data.id is string && data.id.size() <= 128
        && data.title is string && data.title.size() <= 100
        && data.unlocked is bool;
    }

    function isValidChatMessage(data) {
      return data.id is string && data.id.size() <= 128
        && data.sender in ['user', 'coach']
        && data.text is string && data.text.size() <= 10000
        && data.timestamp is string;
    }

    function isValidReport(data) {
      return data.id is string && data.id.size() <= 128
        && data.insights is string && data.insights.size() <= 20000
        && data.generatedAt is string;
    }

    // --- COLLECTION MATCHING ---

    match /users/{userId} {
      allow read, write: if isOwner(userId);
      
      // Hobbies subcollection
      match /hobbies/{hobbyId} {
        allow read, write: if isOwner(userId);
      }

      // Achievements subcollection
      match /achievements/{achievementId} {
        allow read, write: if isOwner(userId);
      }

      // Chat History subcollection
      match /chat_messages/{messageId} {
        allow read, write: if isOwner(userId);
      }

      // AI Reports subcollection
      match /ai_reports/{reportId} {
        allow read, write: if isOwner(userId);
      }
    }
  }
}

